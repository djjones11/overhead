# Copy this file to `.env` and fill in your details.
# All variables are read by the backend (see backend/app/config.py).

# --- Your home location -----------------------------------------------------
# Find these with any map (e.g. right-click "What's here?" on Google Maps,
# or Geohack on Wikipedia). Decimal degrees, negative for South/West.
HOME_LAT=51.5074
HOME_LON=-0.1278

# Search radius around your home, in kilometres.
RADIUS_KM=5.0

# --- ADS-B data source -------------------------------------------------------
# One of: adsbfi | adsbexchange | opensky
# adsbfi is free and requires no key or account - good default.
ADSB_PROVIDER=adsbfi

# Only needed if ADSB_PROVIDER=adsbexchange (RapidAPI key for ADS-B Exchange).
ADSBEXCHANGE_API_KEY=

# Only needed if ADSB_PROVIDER=opensky and you want higher rate limits.
# Register a free client at https://opensky-network.org/my-opensky
OPENSKY_CLIENT_ID=
OPENSKY_CLIENT_SECRET=

# --- Polling behaviour --------------------------------------------------------
POLL_INTERVAL_SECONDS=4
AIRCRAFT_STALE_SECONDS=20
MIN_ALTITUDE_FT=0
APPROACH_BONUS_THRESHOLD_DEG=30

# --- Photos --------------------------------------------------------------------
ENABLE_PHOTO_LOOKUP=true

# --- Misc -----------------------------------------------------------------------
LOG_LEVEL=INFO
CORS_ORIGINS=["*"]
